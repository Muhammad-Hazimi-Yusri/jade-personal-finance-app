# ============================================================================
# Jade — Environment configuration template
# Copy to `.env` and fill in the values you need. Unset variables fall back to
# sensible defaults in docker-compose.yml and litestream.yml.
# ============================================================================

# ---- Demo mode --------------------------------------------------------------
# Set to "true" to show the demo banner, surface the X-Demo-Mode response
# header, and block write requests (POST/PUT/PATCH/DELETE) at the API layer.
DEMO_MODE=false

# ---- Cloudflare Access JWT verification (Phase 7 hardening) -----------------
# Defence-in-depth on top of Cloudflare Access. When BOTH variables are set,
# every request must carry a valid `Cf-Access-Jwt-Assertion` header signed by
# Cloudflare for this Access application. Leave either blank to disable
# verification (e.g. for local dev). DEMO_MODE=true and the /health endpoint
# always bypass verification.
#
# CF_ACCESS_AUD — the application's Audience (AUD) tag.
#   Find it in: Cloudflare Zero Trust → Access → Applications →
#   <Jade (Production)> → Overview → "Application Audience (AUD) Tag".
#   Looks like a 64-character hex string.
#
# CF_ACCESS_TEAM_DOMAIN — your Zero Trust team domain (no scheme, no path).
#   Find it in: Cloudflare Zero Trust → Settings → Custom Pages
#   (or Settings → General → Team domain).
#   Looks like: yourteam.cloudflareaccess.com
CF_ACCESS_AUD=
CF_ACCESS_TEAM_DOMAIN=

# ---- Litestream backup (opt-in) --------------------------------------------
# Only used by the `litestream` service (docker compose --profile backup up -d).
# Works with any S3-compatible storage — R2, Backblaze B2, AWS S3, MinIO.
#
# For Cloudflare R2:
#   - ENDPOINT: https://<account-id>.r2.cloudflarestorage.com
#   - REGION:   auto
# For AWS S3:
#   - ENDPOINT: https://s3.<region>.amazonaws.com
#   - REGION:   e.g. eu-west-2
S3_ACCESS_KEY=your_access_key_id_here
S3_SECRET_KEY=your_secret_access_key_here
LITESTREAM_BUCKET=jade-backups
LITESTREAM_ENDPOINT=https://YOUR_R2_ACCOUNT.r2.cloudflarestorage.com
LITESTREAM_PATH=db
LITESTREAM_REGION=auto
